{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],

    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,

    "noEmit": true,
    "incremental": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",

    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,

    "jsx": "preserve",

    "baseUrl": ".",

    "paths": {
      "@/*": ["./src/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}
