# ======================================================
# Application
# ======================================================

NODE_ENV=development

NEXT_PUBLIC_APP_NAME="Tamer Studio"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ======================================================
# Database
# ======================================================

DATABASE_URL="postgresql://username:password@localhost:5432/tamer_studio"

# ======================================================
# Authentication
# ======================================================

AUTH_SECRET="replace-with-a-secure-random-secret"
AUTH_URL="http://localhost:3000"

# ======================================================
# Object Storage (Cloudflare R2)
# ======================================================

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ======================================================
# AI Gateway
# ======================================================

AI_GATEWAY_PROVIDER="kilo"

KILO_API_KEY=""
OPENROUTER_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
ANTHROPIC_API_KEY=""

# ======================================================
# Payment (iPaymu)
# ======================================================

IPAYMU_API_KEY=""
IPAYMU_VA=""
IPAYMU_ENVIRONMENT="sandbox"

# ======================================================
# Email
# ======================================================

SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ======================================================
# Queue / Background Jobs
# ======================================================

TRIGGER_SECRET_KEY=""

# ======================================================
# Monitoring
# ======================================================

SENTRY_DSN=""

# ======================================================
# Feature Flags
# ======================================================

FEATURE_AFFILIATE=true
FEATURE_DRAMA=true
FEATURE_STORY=false
FEATURE_TALENT=false
FEATURE_ADMIN=true
